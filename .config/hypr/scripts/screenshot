#!/usr/bin/env bash
set -euo pipefail

OUTDIR="${XDG_PICTURES_DIR:-$HOME/pictures}/Screenshots"
mkdir -p "$OUTDIR"

timestamp() { date -u +"%Y-%m-%dT%H:%M:%S"; }
OUTFILE="$OUTDIR/screenshot-$(timestamp).png"

err() {
    printf '%s\n' "$1" >&2
    exit "${2:-1}"
}

case "${1:-}" in
"")
    command -v grim >/dev/null || err "grim not found"
    grim "$OUTFILE"
    notify-send -i "$OUTFILE" "Screenshot saved" "$OUTFILE"
    ;;

-s)
    command -v slurp >/dev/null || err "slurp not found"
    command -v grim >/dev/null || err "grim not found"
    GEOM="$(slurp)" || err "slurp canceled or failed"
    grim -g "$GEOM" "$OUTFILE"
    notify-send -i "$OUTFILE" "Screenshot saved (selection)" "$OUTFILE"
    ;;

-w)
    command -v hyprctl >/dev/null || err "hyprctl not found"
    command -v grim >/dev/null || err "grim not found"
    INFO="$(hyprctl activewindow)" || err "failed to get activewindow info"
    X="$(printf '%s' "$INFO" | sed -n 's/.*at: \([0-9-]\+\),\([0-9-]\+\).*/\1/p')"
    Y="$(printf '%s' "$INFO" | sed -n 's/.*at: \([0-9-]\+\),\([0-9-]\+\).*/\2/p')"
    W="$(printf '%s' "$INFO" | sed -n 's/.*size: \([0-9-]\+\),\([0-9-]\+\).*/\1/p')"
    H="$(printf '%s' "$INFO" | sed -n 's/.*size: \([0-9-]\+\),\([0-9-]\+\).*/\2/p')"
    [ -n "$X" ] || err "failed to parse X"
    [ -n "$Y" ] || err "failed to parse Y"
    [ -n "$W" ] || err "failed to parse W"
    [ -n "$H" ] || err "failed to parse H"
    GEOM="${X},${Y} ${W}x${H}"
    grim -g "$GEOM" "$OUTFILE"
    notify-send -i "$OUTFILE" "Screenshot saved (window)" "$OUTFILE"
    ;;

*)
    err "Usage: $0 [ -s | -w ]" 2
    ;;
esac
